# ── Server ─────────────────────────────────────────────────────────────
PORT=3000

# Public HTTPS URL where this server is reachable.
# Local dev: use your ngrok URL (or reserve a static domain).
# Hosted:    use your Render / Fly / Cloudflare URL.
# Example:   https://your-app.onrender.com
BASE_URL=https://REPLACE_ME.example.com

# ── Salesforce ──────────────────────────────────────────────────────────
# Production org:  https://login.salesforce.com
# Sandbox org:     https://test.salesforce.com
SF_LOGIN_URL=https://login.salesforce.com

# ── Salesforce Connected App (only needed for standalone clients) ────────
# For Claude connector: user provides their own Client ID/Secret in the form.
# For n8n / Cursor / standalone clients: set these here so /auth can use them.
SF_CLIENT_ID=YOUR_SF_CONNECTED_APP_CONSUMER_KEY
SF_CLIENT_SECRET=YOUR_SF_CONNECTED_APP_CONSUMER_SECRET

# ── Optional: user credentials for tools that impersonate a specific user ──
# LEAVE BLANK unless you specifically need a username-password grant.
# Never commit real values here — copy this to .env locally and fill in .env only.
SF_USERNAME=
SF_PASSWORD=

# Callback URL — for standalone auth flow (not the Claude connector).
# Must exactly match one of the Callback URLs whitelisted in your SF Connected App.
SF_REDIRECT_URI=https://REPLACE_ME.example.com/auth/callback
